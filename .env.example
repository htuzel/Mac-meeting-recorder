# Meeting Recorder Configuration
# ────────────────────────────────────────────────────────────────
# Copy this file and fill in your values:
#   mkdir -p ~/.config/meeting-recorder
#   cp .env.example ~/.config/meeting-recorder/.env

# ── Required ─────────────────────────────────────────────────────

# Gladia API key — get yours free at https://app.gladia.io
GLADIA_API_KEY=your_gladia_api_key_here

# ── Transcription ─────────────────────────────────────────────────

# Language of the meeting audio (ISO 639-1 code)
# Examples: tr (Turkish), en (English), de (German), fr (French)
# Full list: https://docs.gladia.io
TRANSCRIPTION_LANGUAGE=tr

# ── Storage ───────────────────────────────────────────────────────

# Where to save recordings (default: ~/MeetingRecordings)
# RECORDINGS_DIR=~/MeetingRecordings

# ── Audio ─────────────────────────────────────────────────────────

# Audio sample rate in Hz (default: 48000)
# SAMPLE_RATE=48000

# ── Voice Activity Detection ──────────────────────────────────────

# Both mic AND system audio must be active for this many seconds
# before recording starts. Higher = fewer false positives. (default: 5)
# VAD_ACTIVATION_SECONDS=5

# Silence duration before stopping a recording (seconds, default: 45)
# VAD_SILENCE_TIMEOUT=45

# Cooldown after silence before returning to idle (seconds, default: 15)
# VAD_COOLDOWN_SECONDS=15

# How often to sample audio levels (seconds, default: 0.5)
# VAD_CHECK_INTERVAL=0.5

# Microphone RMS level considered "active" (0.0–1.0, default: 0.01)
# VAD_MIC_THRESHOLD=0.01

# System audio RMS level considered "active" (0.0–1.0, default: 0.005)
# VAD_SYSTEM_THRESHOLD=0.005
