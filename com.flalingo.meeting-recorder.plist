<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.flalingo.meeting-recorder</string>
    <key>ProgramArguments</key>
    <array>
        <string>__APP_PATH__/Contents/MacOS/MeetingRecorder</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <dict>
        <key>SuccessfulExit</key>
        <false/>
    </dict>
    <key>StandardOutPath</key>
    <string>__LOGS_DIR__/launchd_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>__LOGS_DIR__/launchd_stderr.log</string>
    <key>ProcessType</key>
    <string>Interactive</string>
</dict>
</plist>
